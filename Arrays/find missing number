class Solution:
    def missingNumber(self, nums: List[int]) -> int:
        n=len(nums)
        sum1=0
        sum2=0
        for i in range(0,n+1):
            sum1+=i
        for i in range(len(nums)):
            sum2+=nums[i]
        result=sum1-sum2
        return result
        
        


        
